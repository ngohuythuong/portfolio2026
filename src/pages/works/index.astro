---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../../components/ProjectCard.astro";
const allWorks = await getCollection("works");
// Sắp xếp dự án theo stt
const sortedWorks = allWorks.sort((a, b) =>
  a.data.project_hero.metadata.stt.localeCompare(
    b.data.project_hero.metadata.stt,
  ),
);
---

<BaseLayout title="Works">
  <section class="works">
    <div class="container">
      <div class="works__heading">
        <h1 class="text-h1" data-split-text-anim="word" 
            data-settings='{ "repeat": true}'>Our Projects</h1>
        <div class="view-switch">
          <span
            class="view-switch__btn view-switch__btn--active"
            data-view="list">List</span
          >
          <div class="view-switch__divider">/</div>
          <span class="view-switch__btn" data-view="grid">Grid</span>
        </div>
      </div>
    </div>
    <div class="container container--flush">
      <div class="works__list">
        {sortedWorks.map((work) => <ProjectCard project={work} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .works {
    padding: 15rem 0 4rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6rem;
  }

  .works__list {
    display: flex;
    flex-direction: column;
  }

  .works__list--grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem 2rem;
    padding: 0 3rem;
  }

  .works__heading {
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: end;
    gap: 3rem 1.5rem;
    flex-wrap: wrap;
  }

  .works__heading .text-h1 {
    flex: 1;
    text-align: left;
  }

  .view-switch {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    width: auto;
    margin-bottom: 0.5rem;
  }

  .view-switch .view-switch__btn {
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.06rem;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0.4;
    transition: opacity 0.3s ease;
    user-select: none;
  }

  .view-switch .view-switch__btn--active {
    opacity: 1;
  }

  .view-switch__divider {
    font-size: 0.875rem;
    opacity: 0.4;
  }

  @media (max-width: 767px) {
    .works {
      padding: 10rem 0 4rem 0;
      gap: 1rem;
    }

    .view-switch {
      width: 100%;
    }

    .works__list--grid {
      grid-template-columns: repeat(1, 1fr);
      gap: 2rem;
      padding: 0 1.25rem;
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    .works__list--grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 1.5rem;
      padding: 0 2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const container = document.querySelector(".works__list") as HTMLElement;
  const cards = document.querySelectorAll<HTMLElement>(".project-card");
  const labels = document.querySelectorAll<HTMLElement>(
    ".view-switch .view-switch__btn[data-view]",
  );

  let currentView = "list";

  labels.forEach((label) => {
    label.addEventListener("click", () => {
      const targetView = label.getAttribute("data-view");
      if (!targetView || targetView === currentView) return;

      currentView = targetView;

      // 1. Cập nhật trạng thái Active của các nút chuyển đổi UI
      labels.forEach((l) => l.classList.remove("view-switch__btn--active"));
      label.classList.add("view-switch__btn--active");

      // 2. Khởi tạo một Timeline riêng biệt cho mỗi lần click switch layout
      const tl = gsap.timeline();

      // Bước A: Tạo nhịp rơi ẩn nhẹ nhàng cho các card cũ (Fade out)
      tl.to(cards, {
        opacity: 0,
        y: -20,            // Khoảng cách dịch chuyển nhỏ (16px) giúp layout tinh tế, không bị loãng
        duration: 0.3,    // Tốc độ ẩn nhanh để người dùng không phải đợi lâu
        stagger: 0.1,     // Nhịp rơi giữa các card mượt và dày hơn
        ease: "power3.in", // Gia tốc nhanh dần để biến mất dứt khoát
      });

      // Bước B: Thay đổi cấu trúc Class Layout ngay khi vừa biến mất hoàn toàn
      tl.add(() => {
        if (targetView === "grid") {
          container.classList.add("works__list--grid");
          cards.forEach((card) => {
            card.classList.remove("project-card--list");
            card.classList.add("project-card--box");
          });
        } else {
          container.classList.remove("works__list--grid");
          cards.forEach((card) => {
            card.classList.remove("project-card--box");
            card.classList.add("project-card--list");
          });
        }
      });

      // Bước C: Đặt các card ở vị trí chuẩn bị xuất hiện từ dưới lên (Không tốn thời gian chạy)
      tl.set(cards, { 
        y: 20, 
        opacity: 0 
      });

      // Bước D: Cho các card ở layout mới xuất hiện tiến lên nhẹ nhàng (Fade in)
      tl.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.3,
        stagger: 0.1,
        ease: "power3.out", // Chậm dần khi về đích, tạo cảm giác các phần tử "hạ cánh" êm ái
      });

    });
  });
</script>
