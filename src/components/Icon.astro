---
interface Props {
  name: "arrow_outward" | "close" | "add";
  class?: string;
}

const { name, class: className } = Astro.props;

// Danh sách các Path SVG - Bạn chỉ cần copy path từ các trang icon vào đây 1 lần duy nhất
const icons = {
  "arrow_outward": "M6.4 18L5 16.6L14.6 7H6V5H18V17H16V8.4L6.4 18Z",
  "close": "m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z",
  "add":"M11 13H5V11H11V5H13V11H19V13H13V19H11V13Z"
};
---

<svg 
  xmlns="http://www.w3.org/2000/svg" 
  height="24" 
  viewBox="0 0 24 24" 
  width="24"
  height="24"
  fill="currentColor" 
  class={className}
  preserveAspectRatio="xMidYMid meet"
>
  <path d={icons[name]} />
</svg>
