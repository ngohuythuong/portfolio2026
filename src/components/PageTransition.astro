---
// src/components/PageTransition.astro
interface Props {
  gridCount?: number;
  staggerType?: "center" | "start" | "end";
  direction?: "up" | "down";
}

const {
  gridCount = 8,
  staggerType = "center",
  direction = "down",
} = Astro.props;

const columns = Array.from({ length: gridCount }, (_, i) => i);
---

<div
  class="transition-overlay"
  data-stagger={staggerType}
  data-direction={direction}
  id="page-transition-overlay"
>
  <div class="transition-columns">
    {
      columns.map((index) => (
        <div
          class="transition-column"
          style={`--index: ${index}; --grid: ${gridCount};`}
        />
      ))
    }
  </div>
</div>

<style>
  .transition-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    pointer-events: none;
    visibility: hidden;
  }

  .transition-columns {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
  }

  .transition-column {
    flex: 1;
    height: 100%;
    background-color: #111111;
    transform: scaleY(0);
    will-change: transform;
  }

  [data-direction="up"] .transition-column {
    transform-origin: bottom center;
  }
  [data-direction="down"] .transition-column {
    transform-origin: top center;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function playTransitionReveal() {
    const overlay = document.getElementById('page-transition-overlay');
    if (!overlay) return;

    const columns = overlay.querySelectorAll('.transition-column');
    const staggerAttr = overlay.getAttribute('data-stagger') || 'center';

    let staggerConfig: any = { each: 0.05 };
    if (staggerAttr === 'center') {
      staggerConfig.from = 'center';
    }

    gsap.to(columns, {
      scaleY: 0,
      duration: 0.5,
      ease: "power4.inOut",
      stagger: staggerConfig,
      onComplete: () => {
        overlay.style.pointerEvents = 'none';
        overlay.style.visibility = 'hidden';
      }
    });
  }

  // Attach to window so LoaderCaption can access it
  (window as any).playTransitionReveal = playTransitionReveal;

  function initPageTransitions() {
    const defaultOverlay = document.getElementById('page-transition-overlay');
    const staggerAttr = defaultOverlay?.getAttribute('data-stagger') || 'center';

    let staggerConfig: any = { each: 0.05 };
    if (staggerAttr === 'center') {
      staggerConfig.from = 'center';
    }

    document.addEventListener('astro:before-preparation', (e: any) => {
      const originalLoader = e.loader;

      e.loader = async () => {
        const currentOverlay = document.getElementById('page-transition-overlay');
        if (currentOverlay) {
          const currentColumns = currentOverlay.querySelectorAll('.transition-column');
          currentOverlay.style.pointerEvents = 'auto';
          currentOverlay.style.visibility = 'visible';

          await gsap.to(currentColumns, {
            scaleY: 1,
            duration: 0.5,
            ease: "power4.inOut",
            stagger: staggerConfig
          }).then();
        }

        await originalLoader();
      };
    });

    document.addEventListener('astro:after-swap', () => {
      // Hủy tất cả các ScrollTrigger cũ để tránh lỗi xung đột khi chuyển trang SPA
      ScrollTrigger.getAll().forEach(t => t.kill());

      // Xóa Loader ngay lập tức khi chuyển trang (vì HTML mới được swap vào sẽ mang theo Loader)
      document.querySelector('.loader--caption')?.remove();

      // Thiết lập DOM mới vừa load xong về trạng thái đen toàn màn hình (scaleY: 1)
      const currentOverlay = document.getElementById('page-transition-overlay');
      if (currentOverlay) {
        const currentColumns = currentOverlay.querySelectorAll('.transition-column');
        currentOverlay.style.visibility = 'visible';
        currentOverlay.style.pointerEvents = 'auto';
        gsap.set(currentColumns, { scaleY: 1 });
      }

      playTransitionReveal();
    });
  }

  initPageTransitions();
</script>
